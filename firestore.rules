rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
         (request.auth.token.email == "mohamed.lakicha@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isMentor() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Mentor', 'Admin'];
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['Admin', 'Teacher', 'Mentor', 'User'];
    }

    function isValidReport(data) {
      return data.keys().hasAll(['category', 'location', 'description', 'status', 'timestamp']) &&
             data.category in ['FGM Risk', 'Flood Alert', 'Emergency', 'Other'] &&
             data.status in ['Pending', 'In Progress', 'Resolved'] &&
             data.description.size() < 5000 &&
             data.location.size() < 500;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data);
      allow update: if (isAdmin() && isValidUser(request.resource.data)) || 
                      (isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role);
    }

    match /reports/{reportId} {
      allow read: if isMentor() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
      allow create: if isValidReport(request.resource.data);
      allow update: if isMentor() && isValidReport(request.resource.data);
      allow delete: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
